# Flask 配置
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=dev-key-123456

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=diet_recommend

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 大模型引擎选择：ollama 或 deepseek
LLM_ENGINE=ollama

# Ollama 配置（LLM_ENGINE=ollama 时使用）
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# DeepSeek API 配置（LLM_ENGINE=deepseek 时使用）
DEEPSEEK_API_KEY=sk-your-api-key-here